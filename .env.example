# Admin console — the only email allowed to request OTPs (your personal email)
ADMIN_EMAIL=your@email.com

# Vercel Blob — icon uploads in admin console
# Auto-set by Vercel in production; get dev token from Vercel dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# GitHub — optional, raises rate limit from 60/hr to 5000/hr
# GITHUB_TOKEN=ghp_your_token_here

# Resend — Contact form + daily digest + admin OTP emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address — must be from a verified domain in Resend
FROM_EMAIL=noreply@yourdomain.com

# Recipient address — where contact form submissions and daily digest are sent
CONTACT_EMAIL=contact@yourdomain.com

# Public contact email — shown in the Contact section of the portfolio
NEXT_PUBLIC_CONTACT_EMAIL=contact@yourdomain.com

# Upstash Redis — Visitor counter + content storage
# Get these from https://upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Vercel Cron — Daily digest auth
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
